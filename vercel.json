{
  "buildCommand": "node inject-script.js",
  "outputDirectory": ".",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/admin", "destination": "/dashboard.html" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
